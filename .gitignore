# Ignore system-specific files
.DS_Store
Thumbs.db

# Ignore local configuration files
*.env

# Ignore SQL Server-related files
*.mdf
*.ldf
*.ndf

# Ignore temporary or backup files
*.log
*.bak
*.tmp

# Ignore IDE-specific files
.vscode/
.idea/

# Ignore exported data or diagrams (if applicable)
*.csv
*.png
*.pdf

# Allow README/documentation visuals inside docs/images
!docs/images/
!docs/images/*.png
!docs/images/*.jpg
!docs/images/*.jpeg
!docs/images/*.gif
!docs/images/*.webp
